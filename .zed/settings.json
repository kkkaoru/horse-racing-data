{
  "lsp": {
    "oxlint": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onType",
          "disableNestedConfig": false,
          "fixKind": "safe_fix",
          "typeAware": true,
          "unusedDisableDirectives": "deny"
        }
      }
    },
    "oxfmt": {
      "initialization_options": {
        "settings": {
          "configPath": null,
          "run": "onSave"
        }
      }
    },
    "basedpyright": {
      "settings": {
        "python.pythonPath": "apps/pc-keiba-viewer/.venv/bin/python",
        "python.venvPath": "apps/pc-keiba-viewer",
        "basedpyright.analysis": {
          "diagnosticMode": "openFilesOnly",
          "extraPaths": ["apps/pc-keiba-viewer/src/scripts", "scripts", "scripts/stubs"],
          "typeCheckingMode": "strict",
          "useLibraryCodeForTypes": true,
          "autoSearchPaths": true,
          "diagnosticSeverityOverrides": {
            "reportAny": "none",
            "reportMissingModuleSource": "none",
            "reportUnknownArgumentType": "none",
            "reportUnknownLambdaType": "none",
            "reportUnknownMemberType": "none",
            "reportUnknownVariableType": "none"
          }
        }
      }
    }
  },
  "languages": {
    "Python": {
      "language_servers": ["basedpyright", "!pyright", "..."]
    },
    "JavaScript": {
      "language_servers": ["!biome", "..."],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        },
        {
          "code_action": "source.fixAll.oxc"
        }
      ]
    },
    "TypeScript": {
      "language_servers": ["!biome", "..."],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
          "language_server": {
            "name": "oxfmt"
          }
        },
        {
          "code_action": "source.fixAll.oxc"
        }
      ]
    },
    "TSX": {
      "language_servers": ["!biome", "..."],
      "format_on_save": "on",
      "prettier": {
        "allowed": false
      },
      "formatter": [
        {
