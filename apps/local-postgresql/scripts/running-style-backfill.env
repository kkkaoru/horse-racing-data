# =============================================================================
# running-style-backfill.env
# -----------------------------------------------------------------------------
# 21y horse-race running-style feature backfill driver parameters.
#
# Sourced by `run-running-style-21y-backfill.sh`. The shell wrapper composes
# the `bun run generate-running-style-local.ts` command line from these
# variables.
#
# Format: shell-source compatible `KEY=VALUE`. No spaces around `=`. The
# wrapper script populates `REPO_ROOT` BEFORE sourcing this file so
# `${REPO_ROOT}` interpolation here resolves correctly.
# =============================================================================

# -----------------------------------------------------------------------------
# Background: bottlenecks found by the 8-way SubAgent investigation
# -----------------------------------------------------------------------------
# 1. PG `parallel workers = 0`:
#    `apps/sync-realtime-data/src/running-style-feature-sql.ts:963-980` uses
#    `WITH ... AS MATERIALIZED (...)` CTEs. The planner emits a `CteScan`
#    node which is parallel-unsafe in PostgreSQL 18, so the entire plan is
#    rejected for parallel workers. Inlining the CTE would let parallelism
#    engage, but `running-style-feature-sql.ts` is FROZEN during the
#    active 21y backfill — do not touch it from this env file.
# 2. DuckDB `postgres_query()` opens the PG attachment with
#    `read_only = false` hard-coded, which forces `max_threads = 1` on the
#    DuckDB side. The `COPY (SELECT) TO STDOUT` wrapper then sends a single
#    serial query to PG, which the PG planner additionally rejects for
#    parallel workers because of (1).
# 3. The only short-term lever is the DRIVER-side fan-out: the
#    `--phase-a-concurrency` flag of generate-running-style-local.ts. The
#    driver runs JRA and NAR in parallel, so
#       effective_N = phase_a_concurrency * 2
#    PG-side concurrency must respect:
#       max_parallel_workers           = 12  (compose.yml)
#       max_parallel_workers_per_gather = 8  (compose.yml)
#       work_mem                       = 64MB (compose.yml)
#       shared_buffers                 = 6GB (compose.yml)
#       container memory limit         = 20g (compose.yml)
#    colima VM has 12 CPU / 24 GiB total, so we leave headroom for the
#    container OS and for DuckDB heap on the driver side.
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Driver concurrency
# -----------------------------------------------------------------------------
# `--phase-a-concurrency` of generate-running-style-local.ts.
# effective_N = PHASE_A_CONCURRENCY * 2 (JRA + NAR run in parallel).
#
# N=2 vs N=3 vs N=4 risk table (assumes work_mem=64MB, 20GB container):
#   PHASE_A_CONCURRENCY=2 -> effective_N=4 -> safest, slowest. PG OOM
#                            risk near zero, BuffileWrite spill rare.
#   PHASE_A_CONCURRENCY=3 -> effective_N=6 -> RECOMMENDED. Headroom for
#                            each session at ~3.3GB PG heap budget,
#                            BuffileWrite spill bounded, throughput ~1.5x.
#   PHASE_A_CONCURRENCY=4 -> effective_N=8 -> matches the previous run
#                            that triggered PG OOM with work_mem=256MB.
#                            Currently feasible only because work_mem is
#                            now 64MB, but each gather can still spawn 8
#                            workers, so heap pressure remains the highest
#                            risk on long-tail months.
PHASE_A_CONCURRENCY=3

# -----------------------------------------------------------------------------
# DuckDB tuning (driver side, NOT PG)
# -----------------------------------------------------------------------------
# `--memory-limit-per-chunk` is the per-chunk DuckDB heap cap. Computed as
#   total_duckdb_heap / effective_N
# We size this so that PHASE_A_CONCURRENCY * 2 chunks * cap stays within
# the colima VM budget AFTER PG's 20GB container reservation:
#   N=4  -> 4GB per chunk (16GB total)
#   N=6  -> 3GB per chunk (18GB total) <- DEFAULT, matches PHASE_A_CONCURRENCY=3
#   N=8  -> 2GB per chunk (16GB total)
DUCKDB_MEMORY_LIMIT_PER_CHUNK=3GB

# `--threads` for DuckDB. Each chunk's DuckDB instance can use this many
# CPU threads. 4 * effective_N=6 = 24 threads target, but DuckDB shares
# the host scheduler with PG (which gets up to 12 parallel workers), so
# 4 is the sweet spot here.
DUCKDB_THREADS=4

# `--memory-limit` is the driver process's overall DuckDB heap (the PG
# attachment / metadata side). Distinct from --memory-limit-per-chunk
# which is the worker-side cap.
DUCKDB_MEMORY_LIMIT=16GB

# -----------------------------------------------------------------------------
# PG parameters (mirrors compose.yml — DO NOT change here without also
# editing apps/local-postgresql/compose.yml; these are documented for
# operators reading this env file in isolation)
# -----------------------------------------------------------------------------
PG_MAX_PARALLEL_WORKERS=12
PG_MAX_PARALLEL_WORKERS_PER_GATHER=8
PG_WORK_MEM=64MB
PG_SHARED_BUFFERS=6GB
PG_CONTAINER_MEMORY_LIMIT=20g

# -----------------------------------------------------------------------------
# Connection / version / artifact paths
# -----------------------------------------------------------------------------
# REPO_ROOT is set by run-running-style-21y-backfill.sh BEFORE sourcing
# this file so the ${REPO_ROOT} expansion below resolves at source time.
PG_URL=postgresql://horse_racing:horse_racing@127.0.0.1:15432/horse_racing
RUNNING_STYLE_FEATURE_VERSION=v1

MODEL_VERSION_JRA=jra-running-style-lgbm-prod-v2
MODEL_VERSION_NAR=nar-running-style-lgbm-prod-v1.5

MODEL_FLATBIN_JRA=${REPO_ROOT}/tmp/models/jra-running-style-lgbm-prod-v2/model.flatbin
RS_P_FROM_FLATBIN_JRA=${REPO_ROOT}/tmp/models/jra-running-style-lgbm-prod-v1.5/model.flatbin
MODEL_FLATBIN_NAR=${REPO_ROOT}/tmp/models/nar-running-style-lgbm-prod-v1.5/model.flatbin

# -----------------------------------------------------------------------------
# Operational flags
# -----------------------------------------------------------------------------
# `--chunk-granularity month`: one chunk per (year, month) per category.
# Smaller chunks bound DuckDB spill and let the year-level resume kick in
# faster on failures. Year-level granularity is too coarse for 21y.
CHUNK_GRANULARITY=month

# `--ignore-night-window 1`: bypass the JST 23-04 night-only guard. The
# 21y backfill is a one-off heavy job and must run continuously.
IGNORE_NIGHT_WINDOW=1

# Where the wrapper redirects stdout/stderr.
LOG_FILE=/tmp/rs-21y-backfill.log
