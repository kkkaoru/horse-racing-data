{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "endOfLine": "lf",
  "ignorePatterns": [
    ".next/**",
    "coverage/**",
    "finish-position/**",
    "logs/**",
    "node_modules/**",
    "tmp/**",
    "tsconfig.tsbuildinfo"
  ],
  "insertFinalNewline": true,
  "jsxSingleQuote": false,
  "printWidth": 100,
  "quoteProps": "as-needed",
  "semi": true,
  "singleAttributePerLine": false,
  "singleQuote": false,
  "sortImports": true,
  "sortPackageJson": true,
  "tabWidth": 2,
  "trailingComma": "all",
  "useTabs": false
}
