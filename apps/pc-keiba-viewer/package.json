{
  "name": "pc-keiba-viewer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "bun run format:check && bun run lint && bun run tsc && bun run test:coverage",
    "dev": "next dev",
    "dev:http-proxy": "bun run src/scripts/dev-http-proxy.ts",
    "dev:configure-access": "bun run src/scripts/configure-access-dev-service-token.ts",
    "dev:production-live-relay": "bun run src/scripts/dev-production-live-relay.ts",
    "dev:https": "PC_KEIBA_CLOUDFLARE_REMOTE_BINDINGS=1 PC_KEIBA_ALLOWED_DEV_ORIGINS=localhost:3000,127.0.0.1:3000,192.168.1.219 next dev --experimental-https --experimental-https-key ./certificates/local-key.pem --experimental-https-cert ./certificates/local.pem -H 0.0.0.0 -p 443",
    "dev:https-with-proxy": "sh -c 'bun run dev:http-proxy & proxy_pid=$!; trap \"kill $proxy_pid\" EXIT INT TERM; bun run dev:https'",
    "dev:https:remote": "PC_KEIBA_CLOUDFLARE_REMOTE_BINDINGS=1 bun run dev:https",
    "dev:build-corner-features": "bun run src/scripts/build-corner-feature-table.ts",
    "dev:compare-corners": "bun run src/scripts/compare-corner-predictions.ts",
    "dev:compare-finish": "bun run src/scripts/compare-finish-position-predictions.ts",
    "dev:compare-running-style": "uv run python src/scripts/finish-position-features/compare-running-style-predictions.py",
    "dev:running-style-walk-forward": "uv run --with lightgbm --with pandas --with numpy --with pyarrow python src/scripts/running_style_lightgbm.py walk-forward",
    "dev:search-finish-tuning": "bun run src/scripts/search-finish-position-tuning.ts",
    "dev:build-finish-features": "bun run src/scripts/finish-position-features/build-finish-position-features.ts",
    "dev:export-finish-features": "bun run src/scripts/finish-position-features/export-finish-position-dataset.ts",
    "dev:import-finish-predictions": "bun run src/scripts/finish-position-features/import-finish-position-predictions.ts",
    "dev:upload-finish-model": "bun run src/scripts/finish-position-features/upload-finish-model.ts",
    "dev:evaluate-predictions": "bun run src/scripts/finish-position-features/evaluate-predictions.ts",
    "dev:finish-lightgbm": "uv run --with lightgbm --with pandas --with numpy --with optuna --with pyarrow python src/scripts/finish_position_lightgbm.py",
    "dev:build-finish-features-duckdb": "uv run python src/scripts/finish_position_features_duckdb.py",
    "dev:walk-forward-finish-eval": "bun run src/scripts/walk-forward-finish-position-eval.ts",
    "dev:walk-forward-win5-eval": "bun run src/scripts/walk-forward-win5-eval.ts",
    "dev:generate-win5-overlay": "bun run src/scripts/generate-win5-overlay.ts",
    "dev:export-corner-lightgbm": "bun run src/scripts/export-corner-lightgbm-dataset.ts",
    "dev:import-corner-lightgbm": "bun run src/scripts/import-corner-lightgbm-predictions.ts",
    "dev:setup-lightgbm-gpu-macos": "bun run src/scripts/setup-lightgbm-gpu-macos.ts",
    "dev:train-corner-model": "bun run src/scripts/train-corner-prediction-model.ts",
    "dev:train-corner-lightgbm": "uv run --with lightgbm --with pandas --with scikit-learn python src/scripts/train-corner-lightgbm.py",
    "dev:local": "PC_KEIBA_DATABASE_TARGET=local next dev",
    "dev:neon": "PC_KEIBA_DATABASE_TARGET=neon next dev",
    "deploy:worker": "opennextjs-cloudflare build && OPEN_NEXT_DEPLOY=true wrangler deploy",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "bun run lint:ts && bun run lint:css",
    "lint:css": "eslint --config eslint.config.mjs \"src/app/**/*.css\"",
    "lint:fix": "bun run lint:ts:fix && bun run lint:css:fix",
    "lint:css:fix": "eslint --config eslint.config.mjs \"src/app/**/*.css\" --fix",
    "lint:ts": "oxlint . --tsconfig ./tsconfig.json --type-aware --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --vitest-plugin --promise-plugin --node-plugin --deny-warnings --max-warnings=0 --report-unused-disable-directives",
    "lint:ts:fix": "oxlint . --tsconfig ./tsconfig.json --type-aware --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --vitest-plugin --promise-plugin --node-plugin --deny-warnings --max-warnings=0 --report-unused-disable-directives --fix",
    "start": "next start",
    "start:local": "PC_KEIBA_DATABASE_TARGET=local next start",
    "start:neon": "PC_KEIBA_DATABASE_TARGET=neon next start",
    "preview:worker": "opennextjs-cloudflare build && wrangler dev",
    "python:check": "bun run python:typecheck && bun run python:ty && bun run python:complexity && bun run python:test",
    "python:complexity": "output=$(uv run python -m mccabe --min 16 src/scripts/corner_lightgbm.py); test -z \"$output\" || (printf '%s\\n' \"$output\" && exit 1)",
    "python:test": "uv run pytest",
    "python:ty": "uv run ty check",
    "python:typecheck": "uv run basedpyright",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/react": "3.0.208",
    "@mediapipe/tasks-genai": "0.10.27",
    "@opennextjs/cloudflare": "1.19.11",
    "ai": "6.0.206",
    "drizzle-orm": "0.45.2",
    "horse-racing-realtime": "workspace:*",
    "next": "16.2.9",
    "pg": "catalog:",
    "pg-cloudflare": "catalog:",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "3.8.1",
    "sync-realtime-data-hot": "workspace:*",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@eslint/css": "1.3.0",
    "@happy-dom/global-registrator": "20.10.4",
    "@testing-library/react": "16.3.2",
    "@types/node": "catalog:",
    "@types/pg": "catalog:",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "catalog:",
    "@webgpu/types": "0.1.70",
    "eslint": "10.5.0",
    "fake-indexeddb": "6.2.5",
    "happy-dom": "20.10.4",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "0.23.0",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "wrangler": "catalog:"
  }
}
