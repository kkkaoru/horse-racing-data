{
  "name": "pc-keiba-viewer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "bun run format:check && bun run lint && bun run tsc && bun run test:coverage",
    "dev": "next dev",
    "dev:local": "PC_KEIBA_DATABASE_TARGET=local next dev",
    "dev:neon": "PC_KEIBA_DATABASE_TARGET=neon next dev",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --tsconfig ./tsconfig.json --type-aware --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --vitest-plugin --promise-plugin --node-plugin --deny-warnings --max-warnings=0 --report-unused-disable-directives",
    "lint:fix": "oxlint . --tsconfig ./tsconfig.json --type-aware --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --vitest-plugin --promise-plugin --node-plugin --deny-warnings --max-warnings=0 --report-unused-disable-directives --fix",
    "start": "next start",
    "start:local": "PC_KEIBA_DATABASE_TARGET=local next start",
    "start:neon": "PC_KEIBA_DATABASE_TARGET=neon next start",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "drizzle-orm": "0.45.2",
    "next": "16.2.6",
    "pg": "8.16.3",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.10",
    "@types/pg": "8.15.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.5",
    "jsdom": "29.1.1",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "typescript": "5.9.3",
    "vitest": "4.1.5"
  }
}
