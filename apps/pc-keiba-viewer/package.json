{
  "name": "pc-keiba-viewer",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check": "bun run format:check && bun run lint && bun run tsc && bun run test:coverage",
    "dev": "next dev",
    "dev:build-corner-features": "bun run src/scripts/build-corner-feature-table.ts",
    "dev:compare-corners": "bun run src/scripts/compare-corner-predictions.ts",
    "dev:export-corner-lightgbm": "bun run src/scripts/export-corner-lightgbm-dataset.ts",
    "dev:import-corner-lightgbm": "bun run src/scripts/import-corner-lightgbm-predictions.ts",
    "dev:setup-lightgbm-gpu-macos": "bun run src/scripts/setup-lightgbm-gpu-macos.ts",
    "dev:train-corner-model": "bun run src/scripts/train-corner-prediction-model.ts",
    "dev:train-corner-lightgbm": "uv run --with lightgbm --with pandas --with scikit-learn python src/scripts/train-corner-lightgbm.py",
    "dev:local": "PC_KEIBA_DATABASE_TARGET=local next dev",
    "dev:neon": "PC_KEIBA_DATABASE_TARGET=neon next dev",
    "deploy:worker": "opennextjs-cloudflare build && OPEN_NEXT_DEPLOY=true wrangler deploy",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "lint": "oxlint . --tsconfig ./tsconfig.json --type-aware --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --vitest-plugin --promise-plugin --node-plugin --deny-warnings --max-warnings=0 --report-unused-disable-directives",
    "lint:fix": "oxlint . --tsconfig ./tsconfig.json --type-aware --import-plugin --react-plugin --jsx-a11y-plugin --nextjs-plugin --vitest-plugin --promise-plugin --node-plugin --deny-warnings --max-warnings=0 --report-unused-disable-directives --fix",
    "start": "next start",
    "start:local": "PC_KEIBA_DATABASE_TARGET=local next start",
    "start:neon": "PC_KEIBA_DATABASE_TARGET=neon next start",
    "preview:worker": "opennextjs-cloudflare build && wrangler dev",
    "python:check": "bun run python:typecheck && bun run python:ty && bun run python:complexity && bun run python:test",
    "python:complexity": "output=$(uv run python -m mccabe --min 16 src/scripts/corner_lightgbm.py); test -z \"$output\" || (printf '%s\\n' \"$output\" && exit 1)",
    "python:test": "uv run pytest",
    "python:ty": "uv run ty check",
    "python:typecheck": "uv run basedpyright",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "tsc": "tsc --noEmit"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "1.19.8",
    "drizzle-orm": "0.45.2",
    "horse-racing-realtime": "workspace:*",
    "next": "16.2.6",
    "pg": "8.16.3",
    "pg-cloudflare": "1.3.0",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "recharts": "3.8.1"
  },
  "devDependencies": {
    "@testing-library/react": "16.3.2",
    "@types/node": "22.19.10",
    "@types/pg": "8.15.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.5",
    "jsdom": "29.1.1",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "typescript": "5.9.3",
    "vitest": "4.1.5",
    "wrangler": "4.90.0"
  }
}
